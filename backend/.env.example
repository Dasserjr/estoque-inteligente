# Copie para backend/.env e preencha.

# PostgreSQL (Railway fornece esta URL em "Connect" do banco)
DATABASE_URL=postgresql://usuario:senha@host:5432/railway

# Assinatura do token de login (troque por algo aleatório e longo)
JWT_SECRET=troque-isto-por-uma-frase-secreta-bem-grande

# Validade do token (a empregada loga uma vez e fica logada)
JWT_EXPIRES_IN=30d

# Auth mínimo: senhas de acesso (estrutura pronta para virar papéis depois)
SENHA_DONO=mudar-senha-dono
SENHA_EMPREGADA=mudar-senha-empregada

# Porta do servidor
PORT=3000

# development (SSL off) ou production (SSL on, padrão Railway)
NODE_ENV=development

# Usado no CORS quando publicar (ex.: https://estoque.up.railway.app)
FRONTEND_URL=
